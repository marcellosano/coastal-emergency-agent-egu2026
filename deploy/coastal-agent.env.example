# Coastal Emergency Agent — environment template.
# Real values live at /opt/coastal-agent.env on the droplet (mode 0640, root:coastal).
# This template ships in the repo so operators know which keys are required.
# Never commit a real .env with credentials.

# === LLM brief composition ===
# Default: OpenRouter + OpenAI SDK (one key, all models, ablation-friendly).
# Swap providers without code changes — change LLM_MODEL only.
# Direct Anthropic: omit LLM_BASE_URL and use an Anthropic key.
LLM_API_KEY=sk-or-v1-...                                # OpenRouter key
LLM_MODEL=anthropic/claude-sonnet-4.6                   # default; ablation = change this
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_ENABLED=true                                        # kill switch: 'false' suppresses LLM calls
LLM_MAX_BRIEFS_PER_DAY=50                               # hard daily cap (~$2.50/day on Claude Sonnet)

# === Email — real-SMTP mode (mock mode renders to dashboard panel only) ===
EMAIL_MODE=real                                         # 'real' or 'mock'
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=coastal-agent@example.com
EMAIL_TO=marcellosano@gmail.com

# === Weather provider ===
WEATHER_PROVIDER=open-meteo                             # free, no auth, marine API supports surge/wave
# WEATHER_API_KEY=                                      # only needed for non-Open-Meteo providers

# === ISPRA tide gauge (free; no auth) ===
ISPRA_GAUGE_ID=lido_diga_sud                            # per case study

# === Dashboard public URL ===
DASHBOARD_BASE_URL=https://coastal.example.com          # used in email deeplinks

# === Paths (override defaults if needed) ===
# STATE_DB_PATH=/var/lib/coastal-agent/state.db
# CORPUS_DIR=/home/coastal/Coastal_Emergency_Agent_EGU26/corpus
# VENDOR_DIR=/home/coastal/Coastal_Emergency_Agent_EGU26/external/gnn_drl_ews_v003_seed2

# === Scheduler ===
# POLL_INTERVAL_SECONDS=3600                             # hourly during incidents

# === Trigger thresholds (per case study) ===
# TRIGGER_ACTIVATION_SURGE_CM=110.0                      # PCE Lido alert threshold
# TRIGGER_STANDDOWN_SURGE_CM=100.0                       # 10 cm hysteresis below activation
# TRIGGER_STANDDOWN_CONSECUTIVE_TICKS=2
